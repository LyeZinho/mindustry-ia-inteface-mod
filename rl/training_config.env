# Default Training Configuration
# Override via command-line arguments to rl/run_training.sh

# Maps to train on (comma-separated, case-sensitive)
TRAINING_MAPS="Ancient Caldera"

# Total environment steps
TRAINING_TIMESTEPS=1000000

# Learning rate
TRAINING_LR=0.0003

# Dashboard settings
DASHBOARD_PORT=5000
DASHBOARD_HOST=localhost

# Restart behavior
MAX_RESTARTS=10
RESTART_DELAYS="5 10 30"  # backoff delays in seconds

# Output directories (created if missing)
MODELS_DIR="rl/models_v2"
LOGS_DIR="rl/logs_v2"

# Server settings
MIMI_HOST="localhost"
MIMI_PORT=9000
